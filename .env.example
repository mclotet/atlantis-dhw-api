# URL of the InfluxDB instance (use http://localhost:8086 for standalone)
DHW_INFLUXDB_URL=http://localhost:8086

# InfluxDB authentication token (must have read access to the bucket below)
DHW_INFLUXDB_TOKEN=

# InfluxDB organisation
DHW_INFLUXDB_ORG=

# InfluxDB bucket containing DHW data
DHW_INFLUXDB_BUCKET=

# InfluxDB measurement name for DHW readings
DHW_INFLUXDB_MEASUREMENT=

# InfluxDB field name for the DHW tank temperature
DHW_INFLUXDB_TEMP_FIELD=
